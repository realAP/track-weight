# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# PostgreSQL connection
DATABASE_URL=postgresql://weighttracker:changeme@db:5432/weighttracker

# Database password (used by docker-compose for PostgreSQL)
DB_PASSWORD=changeme

# Timezone (default: Europe/Berlin)
TZ=Europe/Berlin

# --- Backup (devp1337/backup) ---

# Restic repository name on the SFTP server
BACKUP_RESTIC_REPO=weight-tracker

# Restic encryption password
BACKUP_RESTIC_PASSWORD=your_restic_password_here

# Telegram chat ID for backup notifications (can reuse BOT_TOKEN)
BACKUP_TELEGRAM_CHAT_ID=your_chat_id_here

# SFTP target (e.g. Hetzner Storagebox)
BACKUP_SFTP_HOST=your_storagebox_host
BACKUP_SFTP_USER=your_storagebox_user

# SSH private key (unencrypted, base64-encoded): cat key | base64 -w0
BACKUP_SSH_KEY_BASE64=your_base64_encoded_ssh_key_here

# Backup schedule (cron, default: 2am daily)
BACKUP_CRON=0 2 * * *

# Container hostname shown in Telegram notifications (optional)
BACKUP_HOSTNAME=weight-backup
